// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Member {
  STT       Int     @id
  HoVaTen   String
  Khoa      Int
  Lop       String
  MSSV      String  @unique
  SDT       String
  QueQuan   String
  DiaChi    String
  NgaySinh  String
  SoTheCCCD String?
}
